APP_NAME=FacturacionIVSS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCAL=true

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Configuración de Base de Datos (PostgreSQL por defecto)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=apppostgre
DB_USERNAME=appuser
DB_PASSWORD=apppassword
DB_SCHEMA=public

# Para usar Oracle en lugar de PostgreSQL, descomenta y configura:
# DB_CONNECTION=oracle
# DB_HOST=db
# DB_PORT=1521
# DB_DATABASE=XE
# DB_USERNAME=SECURITY
# DB_PASSWORD=security123
# DB_SCHEMA=SECURITY
# Adicionalmente, se requieren las variables DB_ORACLE_* en config/database.php

BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

SANCTUM_REFRESH_TOKEN_EXPIRATION=10080

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_QUEUE=default
REDIS_CLIENT=predis

CORS_ALLOWED_ORIGINS=http://localhost:5173

ACCESS_TOKEN_EXPIRATION_IN_MINUTES=15
REFRESH_TOKEN_EXPIRATION_IN_DAYS=1

CACHE_TTL=300

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=1440
